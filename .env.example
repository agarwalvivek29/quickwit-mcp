# Quickwit instance base URL (required), e.g. http://localhost:7280
QW_BASE_URL=http://localhost:7280

# HTTP request timeout in seconds (default: 30)
QW_TIMEOUT=30

# Default number of hits returned when a search omits max_hits (default: 20)
QW_DEFAULT_MAX_HITS=20

# Hard upper bound on hits per search (default: 100)
QW_MAX_HITS_CEILING=100

# MCP transport: stdio | streamable-http (default: stdio)
MCP_TRANSPORT=stdio
